# AutoProductSelection optional configuration
#
# Copy these values into your VCP root config.env or your deployment's plugin
# configuration mechanism. Do not commit private agent names or business strategy.

# AgentAssistant agent that gathers product evidence and writes runs/raw or runs/failed.
AUTO_SELECTION_SCOUT_AGENT_NAME=ProductSelectionScout

# AgentAssistant agent that reviews runs/raw and writes runs/scored or runs/failed.
AUTO_SELECTION_REVIEWER_AGENT_NAME=ProductSelectionReviewer

# Optional prefixes used to diagnose AgentAssistant tasks that completed without
# writing the expected handoff file. Include your custom agent file prefixes here.
AUTO_SELECTION_SCOUT_TASK_PREFIXES=APS_SCOUT_,ProductSelectionScout_
AUTO_SELECTION_REVIEWER_TASK_PREFIXES=APS_REVIEWER_,ProductSelectionReviewer_
