# Amazon SP-API credentials. Copy this file to config.env and fill real values.
# Do not commit config.env.

# LWA Client ID / ň«óŠłĚšź»š╝ľšáü
AMAZON_SPAPI_LWA_CLIENT_ID=<YOUR_LWA_CLIENT_ID>

# LWA Client Secret / ň«óŠłĚšź»ň»ćÚĺą
AMAZON_SPAPI_LWA_CLIENT_SECRET=<YOUR_LWA_CLIENT_SECRET>

# Self-authorization Refresh Token. Usually starts with Atzr|
AMAZON_SPAPI_REFRESH_TOKEN=<YOUR_REFRESH_TOKEN>

# Region endpoint:
# North America: https://sellingpartnerapi-na.amazon.com
# Europe: https://sellingpartnerapi-eu.amazon.com
# Far East: https://sellingpartnerapi-fe.amazon.com
AMAZON_SPAPI_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# Marketplace IDs, comma-separated. US: ATVPDKIKX0DER
AMAZON_SPAPI_MARKETPLACE_IDS=ATVPDKIKX0DER

# Seller ID / Merchant Token. Required for Listings Items API.
AMAZON_SPAPI_SELLER_ID=<YOUR_SELLER_ID_OR_MERCHANT_TOKEN>

AMAZON_SPAPI_USER_AGENT=VCP-AmazonSPAPI/0.2
AMAZON_SPAPI_TIMEOUT_MS=60000
AMAZON_SPAPI_MAX_RESULT_BYTES=200000
AMAZON_SPAPI_MAX_DOWNLOAD_BYTES=5242880
AMAZON_SPAPI_STATE_DIR=Plugin/AmazonSPAPI/state
AMAZON_SPAPI_DEBUG=false
