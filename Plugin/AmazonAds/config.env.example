# AmazonAds 插件配置覆盖模板。
#
# 文件名保持为 config.env.example 时不会被运行时加载。
# 如需启用插件级覆盖配置，请复制为：
#
#   Plugin/AmazonAds/config.env
#
# 也可以把同名配置项写入项目根目录 config.env。若插件目录下存在
# config.env，则插件级配置优先级高于根目录进程环境变量。
#
# 不要提交真实 AMAZON_CLIENT_SECRET、AMAZON_REFRESH_TOKEN 或操作口令。
# 插件只会在 VCP 插件加载/重载时读取这个文件。

# MCP 连接配置。AmazonAds 使用自己的配置文件，
# 但要求这个 JSON 文件里存在 mcpServers.amazon_ads，并包含 url 以及
# headers.Authorization / Amazon-Ads-ClientId。
AMAZON_ADS_MCP_CONFIG_PATH=/absolute/path/to/Plugin/AmazonAds/mcp-config/mcp-config.json
AMAZON_ADS_MCP_SERVER_NAME=amazon_ads

# 安全模式。除非正在测试受保护的写操作，否则建议保持 true。
AMAZON_ADS_SAFE_MODE=true

# 请求超时、报表轮询和下载体积限制。
AMAZON_ADS_REQUEST_TIMEOUT_MS=120000
AMAZON_ADS_REPORT_POLL_INTERVAL_MS=30000
AMAZON_ADS_REPORT_MAX_POLL_MS=600000
AMAZON_ADS_REPORT_CREATE_MIN_INTERVAL_MS=3000
AMAZON_ADS_PROBE_MAX_CANDIDATE_FIELDS=4
AMAZON_ADS_MAX_DOWNLOAD_BYTES=5242880

# 默认广告账户上下文。普通查询/报表命令会使用这些默认值；
# 当 AMAZON_ADS_CONTEXT_MODE=FIXED 时，内置 token 刷新也会把这些账户
# 信息写入 MCP headers。
AMAZON_ADS_DEFAULT_ACCOUNT_NAME=<YOUR_ACCOUNT_NAME>
AMAZON_ADS_DEFAULT_ACCOUNT_ID=<YOUR_ADS_ACCOUNT_ID>
AMAZON_ADS_DEFAULT_PROFILE_ID=<YOUR_PROFILE_ID>
AMAZON_ADS_DEFAULT_ENTITY_ID=<YOUR_ENTITY_ID>
AMAZON_ADS_DEFAULT_MARKETPLACE=US

# 本地运行状态目录，用于保存报表索引、字段 preset 缓存和物理报表归档。
# 不配置时默认使用 Plugin/AmazonAds/state。
# AMAZON_ADS_STATE_DIR=Plugin/AmazonAds/state

# 真实写操作口令，例如 apply_target_bid_changes。留空会阻止 apply_* 命令；
# 只读查询、propose_* 建议和报表命令不受影响。
AMAZON_ADS_OPERATION_PASSWORD=

# 插件内置的非 Docker token 刷新。若当前由外部 Docker 刷新器维护
# mcp-config.json，请保持关闭。只有希望 VCP/AmazonAds 自己用
# AMAZON_REFRESH_TOKEN 换取短期 access token，并把新的 Authorization
# header 写入 AMAZON_ADS_MCP_CONFIG_PATH 时，才开启。
AMAZON_ADS_ENABLE_TOKEN_REFRESH=false

# 可选自动刷新。仅在 AMAZON_ADS_ENABLE_TOKEN_REFRESH=true 时生效。
# 开启后插件会在启动时刷新一次，然后每隔
# AMAZON_ADS_TOKEN_REFRESH_INTERVAL_SECONDS 秒刷新一次。手动 refresh_token
# 命令仍可用于修复或排障。
AMAZON_ADS_AUTO_REFRESH_TOKEN=false
AMAZON_ADS_TOKEN_REFRESH_INTERVAL_SECONDS=3000

# Amazon OAuth 凭据。仅当 AMAZON_ADS_ENABLE_TOKEN_REFRESH=true 时必填。
# refresh token 只作为输入使用，不会被写入 mcp-config.json。
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=

# 手动 refresh_token 调用的可选口令。若设置，agent 调用时必须传入
# refreshPassword / refresh_password / requireAdmin / password 中的任一字段，
# 且值必须匹配。插件内部自动刷新不要求 agent 知道这个口令。
AMAZON_ADS_TOKEN_REFRESH_PASSWORD=

# 内置 token 刷新写入 headers 时使用的账户上下文模式。
# FIXED 会写入默认 profile/account headers；其他值会移除固定账户 headers。
AMAZON_ADS_CONTEXT_MODE=FIXED
AMAZON_ADS_MANAGER_ACCOUNT_ID=

# Amazon OAuth token endpoint，通常不要修改。
AMAZON_ADS_TOKEN_URL=https://api.amazon.com/auth/o2/token

DebugMode=false
